# --- Both services (web + worker) ---
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=XXXXXXX
# Web uses production settings. The worker image pins its own
# (config.settings.worker) via the Dockerfile, so it must NOT inherit this value
# — set config.settings.worker explicitly in the worker's deployment env.
DJANGO_SETTINGS_MODULE=config.settings.production

POSTGRES_HOST=XXXXXXXXXX
POSTGRES_PORT=5432
POSTGRES_USER=XXXXXXXXXX
POSTGRES_PASSWORD=XXXXXXXXXX
POSTGRES_DB=XXXXXXXXXX

INITIAL_USER_FIRSTNAME=Foo
INITIAL_USER_LASTNAME=Bar
INITIAL_USER_EMAIL=foo.bar@rijksoverheid.nl

# Comma-separated emails that can access /staff/ (db admin)
STAFF_EMAILS=foo.bar@rijksoverheid.nl

DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_ALLOWED_HOSTS=localhost,0.0.0.0,127.0.0.1

# --- Web only (required at web startup ---
OIDC_CLIENT_ID=XXXXXXXXXX
OIDC_CLIENT_SECRET=XXXXXXXXXXXX
OIDC_DISCOVERY_URL=XXXXXXXXXXXX

# --- Both services (worker runs OTYS sync tasks) ---
OTYS_API_KEY=XXXXXXX
OTYS_URL=https://XXXXXXXX.com
