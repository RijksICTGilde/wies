# Environment for the local background worker
# copied to .env.worker by just setup
# In production, set the same keys with real values"

DJANGO_SETTINGS_MODULE=config.settings.worker
DJANGO_SECRET_KEY=django-insecure-local-worker-key

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=wies
POSTGRES_PASSWORD=wies
POSTGRES_DB=wies

# Worker runs OTYS sync tasks
OTYS_API_KEY=XXXXXXX
OTYS_URL=https://XXXXXXXX.com
