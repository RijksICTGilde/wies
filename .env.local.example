# --- Both services (web + worker) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=wies
POSTGRES_PASSWORD=wies
POSTGRES_DB=wies

# --- Both services (required at Django startup) ---
OIDC_CLIENT_ID=XXXXXXXXXX
OIDC_CLIENT_SECRET=XXXXXXXXXXXX
OIDC_DISCOVERY_URL=XXXXXXXXXXXX

# --- Both services (worker runs OTYS sync tasks) ---
OTYS_API_KEY=XXXXXXX
OTYS_URL=https://XXXXXXXX.com

# --- Initial user (bootstrap admin for both dev and production) ---
INITIAL_USER_FIRSTNAME=Foo
INITIAL_USER_LASTNAME=Bar
INITIAL_USER_EMAIL=foo.bar@rijksoverheid.nl

# Comma-separated emails that can access /staff/ (db admin)
STAFF_EMAILS=foo.bar@rijksoverheid.nl

# Enable destructive /staff/ actions (clear data, load dummy data). Off in production.
ENABLE_DESTRUCTIVE_STAFF_ACTIONS=true

# If you want to skip SSO
SKIP_OIDC=false

# --- Rijksprofielservice (PoC) ---
# Browser URL (consent-scherm; user must reach this) keeps the default
# http://localhost:8000 and does not need to be set.
RIJKSPROFIELSERVICE_CLIENT_SECRET=XXXXXXXX
RIJKSPROFIELSERVICE_M2M_CLIENT_SECRET=XXXXXXXX
# Back-channel URLs from inside the Wies container. On macOS/Windows Docker
# Desktop, host.docker.internal resolves to the host. On Linux, add
# `extra_hosts: ["host.docker.internal:host-gateway"]` to the django service.
RIJKSPROFIELSERVICE_API_URL=http://host.docker.internal:8000
RIJKSPROFIELSERVICE_TOKEN_URL=http://host.docker.internal:8081/realms/profielservice/protocol/openid-connect/token
# Override Host header so the profile service's ALLOWED_HOSTS check passes
# (it accepts "localhost" but not "host.docker.internal").
RIJKSPROFIELSERVICE_API_HOST_HEADER=localhost:8000
